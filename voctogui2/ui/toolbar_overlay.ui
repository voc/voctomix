                                                            <class name="option"/>
                                                            <class name="insertion"/>
                                                            <class name="overlay"/>
                                                            </style>
                                                          </object>
                                                        </child>
                                                        <child>
                                                          <object class="GtkButton" id="update-inserts">
                                                            <property name="label" translatable="yes">UPDATE</property>
                                                            <property name="name">update</property>
                                                            <property name="visible">True</property>
                                                            <property name="can-focus">False</property>
                                                            <property name="receives-default">False</property>
                                                            <property name="tooltip-text" translatable="yes">Update current event</property>
                                                          </object>
                                                        </child>
                                                        <child>
                                                          <object class="GtkComboBox" id="inserts">
                                                            <property name="name">inserts</property>
                                                            <property name="visible">True</property>
                                                            <property name="can-focus">False</property>
                                                            <property name="focus-on-click">False</property>
                                                            <property name="tooltip-text" translatable="yes">Select insert (overlay) from preconfigured ones </property>
                                                            <property name="model">insert-store</property>
                                                            <!--<property name="column-span-column">0</property>-->
