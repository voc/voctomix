                                                        <property name="margin-bottom">2</property>
                                                        <property name="wrap">True</property>
                                                        <attributes>
                                                          <attribute name="style" value="oblique"/>
                                                        </attributes>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkBox">
                                                        <property name="visible">True</property>
                                                        <property name="can-focus">False</property>
                                                        <!--<property name="margin-left">8</property>-->
                                                        <!--<property name="margin-right">8</property>-->
                                                        <property name="spacing">6</property>
                                                        <child>
                                                          <object class="GtkCheckButton" id="insert-auto-off">
                                                            <property name="label" translatable="yes">AUTO-OFF</property>
                                                            <property name="name">auto-off</property>
                                                            <property name="visible">True</property>
                                                            <property name="can-focus">False</property>
                                                            <property name="receives-default">False</property>
                                                            <property name="tooltip-text" translatable="yes">automatically turn off insertion before every mix</property>
                                                            <property name="active">True</property>
                                                            <!--<property name="draw-indicator">False</property>-->
